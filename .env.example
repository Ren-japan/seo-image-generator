GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Drive ストレージ（オプション） ---
# 設定するとサイト設定・参照画像・生成画像がGoogle Driveに保存される
# 未設定ならローカルファイルシステム（従来どおり）
#
# 共有ドライブ内のルートフォルダID
# GOOGLE_DRIVE_FOLDER_ID=your_shared_drive_folder_id
#
# サービスアカウント認証（どちらか一方を設定）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account-key.json
#
# Drive内のフォルダ構造（自動作成される）:
#   ルートフォルダ/
#   ├── {サイト名}.json          ← サイト設定
#   ├── _default.json            ← デフォルト設定
#   ├── {サイト名}_ref_images/   ← 参照画像
#   │   ├── article/
#   │   └── mv/
#   └── generated/               ← 生成画像（自動保存）
#       └── {サイト名}/
#           ├── article/
#           └── mv/
